generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("pending") // "pending" ou "completed"
  createdAt   DateTime @default(now()) 
  updatedAt   DateTime @updatedAt      // atualizado automaticamente a cada mudança
}